  "body": {
    "format": "articles",
    "article_count": 6,
    "articles": [
      {
        "article_no": "제1조",
        "article_title": "목적",
        "chapter": "",
        "content": "제1조(목적) 이 규칙은 국회법 제124조제2항 및 국회에서의증언ㆍ감정등에관한법률 제3조의 규정에 의하여 증인ㆍ감정인 및 참고인(이하 證人등이라 한다)에게 지급할 비용의 지급기준을 규정함을 목적으로 한다.",
        "enforcement_date": "19810401",
        "relations": [],
        "images": [],
        "provision_id": "law:국회에서의증인등비용지급에관한규칙#JO0001"
      },
      {
        "article_no": "제2조",
        "article_title": "비용",
        "chapter": "",
        "content": "제2조(비용)\n①증인등에 지급하는 비용은 운임(鐵道ㆍ船舶ㆍ航空 및 自動車)ㆍ현지교통비ㆍ숙박료 ㆍ식비 및 식탁료로 한다.\n②제1항의 비용 이외에 감정을 위하여 의장이 특히 필요하다고 인정하는 경우에는 따로 감정료를 지급할 수 있다.",
        "enforcement_date": "19810401",
        "relations": [],
        "images": [],
        "provision_id": "law:국회에서의증인등비용지급에관한규칙#JO0002"
      },
      {
        "article_no": "제3조",
        "article_title": "비용지급의 예외",
        "chapter": "",
        "content": "제3조(비용지급의 예외) 다음 각호의 1에 해당하는 자에게는 비용을 지급하지 아니한다.\n1.  국회의원\n2.  국무위원ㆍ정부위원\n3.  소속기관에서 따로 비용을 지급받은 공무원과 국영기업체 및 정부투자기관의 임직원",
        "enforcement_date": "19810401",
        "relations": [],
        "images": [],
        "provision_id": "law:국회에서의증인등비용지급에관한규칙#JO0003"
      },
      {
        "article_no": "제4조",
        "article_title": "비용의 지급기준",
        "chapter": "",
        "content": "제4조(비용의 지급기준) 증인등에 대한 비용지급에 관하여는 정부 국내여비규정 별표 2의 제3호를 준용한다.",
        "enforcement_date": "19810401",
        "relations": [],
        "images": [],
        "provision_id": "law:국회에서의증인등비용지급에관한규칙#JO0004"
      },
      {
        "article_no": "제5조",
        "article_title": "비용지급일수의 계산",
        "chapter": "",
        "content": "제5조(비용지급일수의 계산) 증인등에 지급하는 현지교통비, 숙박료 및 식비는 증인등이 국회 또는 지정된 장소에 출석한 날로부터 증인으로서 체재한 일수에 의하여 이를 산정한다.",
        "enforcement_date": "19810401",
        "relations": [],
        "images": [],
        "provision_id": "law:국회에서의증인등비용지급에관한규칙#JO0005"
      },
      {
        "article_no": "제6조",
        "article_title": "비용지급의 제한",
        "chapter": "",
        "content": "제6조(비용지급의 제한) 증인등이 허위의 진술이나 감정을 하였다고 인정할 만한 명백한 사유가 있을 때에는 비용을 지급하지 아니할 수 있다.",
        "enforcement_date": "19810401",
        "relations": [],
        "images": [],
        "provision_id": "law:국회에서의증인등비용지급에관한규칙#JO0006"
      }
    ]
  },
