      {
        "article_no": "제1조",
        "article_title": "목적",
        "chapter": "",
        "content": "제1조 (목적) 이 법은 관광사업을 효율적으로 발전시키고 관광외화수입의 증대에 기여하기 위하여 관광진흥개발기금을 설치함을 목적으로 한다.",
        "enforcement_date": "19721229",
        "relations": [],
        "images": [],
        "provision_id": "law:관광진흥개발기금법#JO0001"
