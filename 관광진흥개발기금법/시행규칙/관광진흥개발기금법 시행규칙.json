  "body": {
    "format": "articles",
    "article_count": 4,
    "articles": [
      {
        "article_no": "제1조",
        "article_title": "목적",
        "chapter": "",
        "content": "제1조 (목적) 이 영은 관광진흥개발기금법(이하 \"법\"이라 한다) 및 동시행령(이하 \"영\"이라 한다)의 시행에 관하여 필요한 사항을 정함을 목적으로 한다.",
        "enforcement_date": "19730705",
        "relations": [],
        "images": [],
        "provision_id": "law:관광진흥개발기금법시행규칙#JO0001"
      },
      {
        "article_no": "제2조",
        "article_title": "기금지출한도액의 통지",
        "chapter": "",
        "content": "제2조 (기금지출한도액의 통지) 교통부장관은 영 제15조의 규정에 의한 기금지출 한도액의 통지를 재무부장관으로부터 받은 때에는 이를 한국산업은행 총재에게 통지한다.",
        "enforcement_date": "19730705",
        "relations": [],
        "images": [],
        "provision_id": "law:관광진흥개발기금법시행규칙#JO0002"
      },
      {
        "article_no": "제3조",
        "article_title": "기금의 대하신청",
        "chapter": "",
        "content": "제3조 (기금의 대하신청) 한국산업은행 총재는 기금을 사용할 자가 결정되어 기금을 대여하고자할 때에는 교통부장관에게 필요한 기금의 대하 신청을 하여야 한다.",
        "enforcement_date": "19730705",
        "relations": [],
        "images": [],
        "provision_id": "law:관광진흥개발기금법시행규칙#JO0003"
      },
      {
        "article_no": "제4조",
        "article_title": "보고",
        "chapter": "",
        "content": "제4조 (보고)\n①영 제18조에 규정에 의한 보고는 매월 사업연도와 기금사용의 내역에 관하여 다음달 10일까지 하여야 한다.\n②제1항의 경우에 법 제5조제1호 내지 제3호 및 영 제2조제1호에 관한 보고는 당해공사등의 착수시부터 완료시까지, 기타의 사항에 관한 보고는 따로 교통부장관이 정하는 바에 따라 이를 하여야 한다.",
        "enforcement_date": "19730705",
        "relations": [],
        "images": [],
        "provision_id": "law:관광진흥개발기금법시행규칙#JO0004"
      }
    ]
  },
