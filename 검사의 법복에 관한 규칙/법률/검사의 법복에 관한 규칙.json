  "body": {
    "format": "articles",
    "article_count": 5,
    "articles": [
      {
        "article_no": "제1조",
        "article_title": "목적",
        "chapter": "",
        "content": "제1조 (목적) 이 규칙은 검사의 법복의 제식 및 모양과 그 대여에 관한 사항을 규정함을 목적으로 한다.",
        "enforcement_date": "20000101",
        "relations": [],
        "images": [],
        "provision_id": "law:검사의법복에관한규칙#JO0001"
      },
      {
        "article_no": "제2조",
        "article_title": "법복",
        "chapter": "",
        "content": "제2조 (법복)\n①검사는 법정에서 법복을 입는다.\n②검사의 법복은 검정색으로 하고, 그 제식은 별표와 같다.",
        "enforcement_date": "20000101",
        "relations": [],
        "images": [],
        "provision_id": "law:검사의법복에관한규칙#JO0002"
      },
      {
        "article_no": "제3조",
        "article_title": "법복의 대여",
        "chapter": "",
        "content": "제3조 (법복의 대여)\n①공판에 관하여는 직무를 수행하는 검사에게는 법복 1벌을 대여한다.\n②법복의 대여기간은 검사가 공판에 관여하는 직무를 수행하는 기간으로 한다.",
        "enforcement_date": "20000101",
        "relations": [],
        "images": [],
        "provision_id": "law:검사의법복에관한규칙#JO0003"
      },
      {
        "article_no": "제4조",
        "article_title": "법복의 재대여등",
        "chapter": "",
        "content": "제4조 (법복의 재대여등)\n①검사가 대여기간중에 법복을 멸실 또는 훼손한 때에는 다시 법복을 대여한다.\n②제1항의 경우에 그 멸실 또는 훼손이 당해 검사의 고의 또는 중대한 과실에 의한 것인 때에는 검사는 그 가액을 변상하여야 한다.",
        "enforcement_date": "20000101",
        "relations": [],
        "images": [],
        "provision_id": "law:검사의법복에관한규칙#JO0004"
      },
      {
        "article_no": "제5조",
        "article_title": "법복의 반납",
        "chapter": "",
        "content": "제5조 (법복의 반납) 검사가 대여기간중에 전직ㆍ휴직ㆍ퇴직 또는 사망한 때에는 법복을 반납하여야 한다.",
        "enforcement_date": "20000101",
        "relations": [],
        "images": [],
        "provision_id": "law:검사의법복에관한규칙#JO0005"
      }
    ]
  },
