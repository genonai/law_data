  "body": {
    "format": "articles",
    "article_count": 21,
    "articles": [
      {
        "article_no": "제1조",
        "article_title": "목적",
        "chapter": "",
        "content": "제1조 (목적) 이 영은 4급이하 교정직공무원의 승진임용에 관한 기준을 확립하여 인사행정의 공정을 기함을 목적으로 한다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0001"
      },
      {
        "article_no": "제2조",
        "article_title": "승진임용의 원칙",
        "chapter": "",
        "content": "제2조 (승진임용의 원칙) 교정직공무원을 승진 임용할 때에는 그 직급의 승진시험에 합격한 자를 임용하여야 한다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0002"
      },
      {
        "article_no": "제3조",
        "article_title": "승진임용의 순위",
        "chapter": "",
        "content": "제3조 (승진임용의 순위) 교정직공무원의 승진임용순위는 그 승진시험에 합격한 성적순으로 한다. 다만, 임용전에 교육을 필요로 하는 경우에는 그 교육성적도 합산한다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0003"
      },
      {
        "article_no": "제4조",
        "article_title": "시험실시기관",
        "chapter": "",
        "content": "제4조 (시험실시기관) 교정직공무원승진시험(이하 \"시험\"이라 한다)은 법무부장관이 이를 관장ㆍ실시한다. 다만, 교도의 시험은 교도소장ㆍ소년교도소장 및 교도관학교장이 이를 실시할 수 있다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0004"
      },
      {
        "article_no": "제5조",
        "article_title": "시험의 종류",
        "chapter": "",
        "content": "제5조 (시험의 종류) 시험은 교감승진시험ㆍ교감보승진시험 및 교도승진시험의 3종으로 한다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0005"
      },
      {
        "article_no": "제6조",
        "article_title": "응시자격",
        "chapter": "",
        "content": "제6조 (응시자격) 교감승진시험에 응시하고자 하는 자는 교감보로 2년이상, 교감보승진시험에 응시하고자 하는 자는 교도로 1년이상, 교도승진시험에 응시하고자 하는 자는 교도보로 1년이상 재직한 자 이어야 한다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0006"
      },
      {
        "article_no": "제7조",
        "article_title": "시험의 방법 및 절차",
        "chapter": "",
        "content": "제7조 (시험의 방법 및 절차)\n①시험은 필기시험과 면접시험으로 구분하여 이를 실시한다.\n②필기시험은 논문형ㆍ선택형ㆍ기입형의 3종으로 과한다. 다만, 법무부장관이 특히 필요하다고 인정할 때에는 논문형 또는 선택형만으로 과할 수 있다.\n③면접시험은 교정실무에 대하여 행하되 그 직무수행에 필요한 응용력 및 적격성을 검정한다.\n④필기시험에 합격하지 아니한 자는 면접시험에 응시할 수 없다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0007"
      },
      {
        "article_no": "제8조",
        "article_title": "시험과목",
        "chapter": "",
        "content": "제8조 (시험과목) 필기시험은 다음의 과목에 대하여 행한다.\n1.  교감승진시험\n가.  행형학\n나.  형법\n다.  형사소송법\n라.  행정법\n2.  교감보승진시험\n가.  행형학\n나.  형법\n다.  형사소송법\n라.  행정법\n3.  교도승진시험\n가.  행형법\n나.  형사소송법\n다.  형법",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0008"
      },
      {
        "article_no": "제9조",
        "article_title": "시험의 시행 및 공고",
        "chapter": "",
        "content": "제9조 (시험의 시행 및 공고)\n①시험은 매년 1회이상 실시할 수 있다.\n②법무부장관은 시험을 실시하고자 할 때에는 그 일시ㆍ장소 기타 시험의 시행에 필요한 사항을 시험기일 20일전에 공고하여야 한다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0009"
      },
      {
        "article_no": "제10조",
        "article_title": "승진시험위원회의 설치 및 구성",
        "chapter": "",
        "content": "제10조 (승진시험위원회의 설치 및 구성)\n①시험을 실시하기 위하여 법무부에 교감ㆍ교감보 및 교도승진시험위원회(이하 \"중앙시험위원회\"라 한다)를 교도소ㆍ소년교도소 및 교도관학교에 교도승진시험위원회(이하 \"지방시험위원회\"라 한다)를 둔다.\n②시험위원회는 위원장과 그 기관의 장이 다음 각호의 1에 해당하는 자 중에서 임명 또는 위촉하는 5인이상의 시험위원으로 구성한다.\n1.  그 시험분야의 전문적인 학식 또는 능력을 가진 자\n2.  시험출제에 관하여 전문적인 지식을 가진 자\n3.  임용예정직무에 대한 실무에 정통한 자\n③중앙시험위원회의 위원장은 법무부차관, 지방시험위원회의 위원장은 그 기관의 장이 된다.\n④위원장은 위원회의 회무를 통리하며 위원회를 대표한다.\n⑤위원장이 사고가 있을 때에는 위원장이 지정하는 위원이 그 직무를 대행한다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0010"
      },
      {
        "article_no": "제11조",
        "article_title": "위원회의 심의사항",
        "chapter": "",
        "content": "제11조 (위원회의 심의사항) 위원회는 다음 각호의 사항을 심의한다.\n1.  시험문제의 출제에 관한 사항\n2.  시험합격자의 결정에 관한 사항\n3.  기타 시험에 관하여 위원장이 심의에 붙이는 사항",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0011"
      },
      {
        "article_no": "제12조",
        "article_title": "위원회의 소집과 의결정족수",
        "chapter": "",
        "content": "제12조 (위원회의 소집과 의결정족수)\n①위원회의 회의는 위원장이 필요하다고 인정할 때에는 이를 소집하여, 그 의장이 된다.\n②위원회의 회의의 의결은 구성원 과반수의 출석과 출석자 과반수의 찬성으로 이를 행한다.\n③의장은 표결권을 가지며, 가부동수인 때에는 결정권을 가진다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0012"
      },
      {
        "article_no": "제13조",
        "article_title": "배점비율",
        "chapter": "",
        "content": "제13조 (배점비율)\n①시험에 있어 배점비율은 필기시험 60퍼센트, 근무성적등 20퍼센트, 면접시험 20퍼센트의 비율로 한다.\n②전항의 근무성적등의 종별 및 종별배점비율은 법무부장관이 정한다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0013"
      },
      {
        "article_no": "제14조",
        "article_title": "시험의 합격결정",
        "chapter": "",
        "content": "제14조 (시험의 합격결정) 시험의 합격결정은 결원인원과 시험성적을 고려하여 고점순으로 합격자를 결정한다. 다만, 매과목 40퍼센트, 전과목 60퍼센트 미만의 득점자는 합격시킬 수 없다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0014"
      },
      {
        "article_no": "제15조",
        "article_title": "합격증서교부 및 훈련",
        "chapter": "",
        "content": "제15조 (합격증서교부 및 훈련)\n①시험에 합격한 자에 대하여는 합격증서를 교부한다.\n②교감보승진시험에 합격한 자(채용시험 및 전직시험에 합격한 자를 포함한다)는 법무부장관이 정하는 바에 따라 임용에 앞서 일정한 기간 교도관학교에서 교육을 받아야 한다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0015"
      },
      {
        "article_no": "제16조",
        "article_title": "시험합격의 유효기간",
        "chapter": "",
        "content": "제16조 (시험합격의 유효기간) 시험합격의 효력은 2년으로 한다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0016"
      },
      {
        "article_no": "제17조",
        "article_title": "부정행위에 대한 제재",
        "chapter": "",
        "content": "제17조 (부정행위에 대한 제재)\n①시험에 있어서는 부정한 행위를 하거나 시험에 관한 규정에 위반한 응시자에 대하여는 그 시험의 응시를 정지시키거나 무효로 하고, 그 응시자는 2년간 사법 및 행정요원 예비시험령ㆍ사법시험령ㆍ공무원임용령 및 이 영의 규정에 의한 시험에 응시할 수 없다.\n②시험에서 부정행위를 한 자에 대하여는 그 응시자의 관할징계위원회에 징계의결을 요구하여야 한다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0017"
      },
      {
        "article_no": "제18조",
        "article_title": "시험위원등에 대한 수당지급",
        "chapter": "",
        "content": "제18조 (시험위원등에 대한 수당지급) 시험위원에 대하여는 예산의 범위안에서 수당을 지급할 수 있다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0018"
      },
      {
        "article_no": "제19조",
        "article_title": "다른 시험과의 관계",
        "chapter": "",
        "content": "제19조 (다른 시험과의 관계) 이 시험에 합격하여 임용된 자가 전직하는 경우에는 전직시험과목중 이미 응시한 과목에 대한 시험은 이를 면제할 수 있다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0019"
      },
      {
        "article_no": "제20조",
        "article_title": "공무원임용령과의 관계",
        "chapter": "",
        "content": "제20조 (공무원임용령과의 관계) 승진임용에 관하여 이 영에 규정하지 아니한 사항은 공무원임용령의 규정에 의한다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0020"
      },
      {
        "article_no": "제21조",
        "article_title": "시행세칙",
        "chapter": "",
        "content": "제21조 (시행세칙) 이 영의 시행에 관하여 필요한 사항은 법무부장관이 정한다.",
        "enforcement_date": "19700216",
        "relations": [],
        "images": [],
        "provision_id": "law:교정직공무원승진임용규정#JO0021"
      }
    ]
  },
