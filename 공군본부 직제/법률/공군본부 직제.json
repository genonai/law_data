  "body": {
    "format": "articles",
    "article_count": 26,
    "articles": [
      {
        "article_no": "제1조",
        "article_title": "직무",
        "chapter": "",
        "content": "제1조 (직무) 공군본부는 공군의 편제ㆍ장비ㆍ기술ㆍ작전ㆍ교육훈련ㆍ후방지원 기타 공군에 관한 사항을 관장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0001"
      },
      {
        "article_no": "제2조",
        "article_title": "참모부장",
        "chapter": "",
        "content": "제2조 (참모부장) 공군본부에 공군참모총장ㆍ공군참모차장 이외에 작전참모부장과 행정참모부장을 둔다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0002"
      },
      {
        "article_no": "제3조",
        "article_title": "작전참모부장",
        "chapter": "",
        "content": "제3조 (작전참모부장) 작전참모부장은 공군의 운영방침 및 계획과 작전에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0003"
      },
      {
        "article_no": "제4조",
        "article_title": "행정참모부장",
        "chapter": "",
        "content": "제4조 (행정참모부장) 행정참모부장은 공군의 행정과 후방지원에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0004"
      },
      {
        "article_no": "제5조",
        "article_title": "비서관",
        "chapter": "",
        "content": "제5조 (비서관)\n①공군본부에 비서관을 둔다.\n②비서관은 공군의 장관급 또는 영관급장교중에서 공군참모총장이 보한다.\n③비서관은 상사의 명을 받아 서무에 종사한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0005"
      },
      {
        "article_no": "제6조",
        "article_title": "참모부서",
        "chapter": "",
        "content": "제6조 (참모부서)\n①공군본부에 다음의 참모부서를 둔다. 다만, 국방부장관은 군사상 필요에 따라 국무총리의 승인을 얻어 참모부서의 폐합 또는 증설을 할 수 있다. 인사국ㆍ정보국ㆍ작전국ㆍ군수국ㆍ관리국ㆍ통신전자국ㆍ시설국ㆍ기획국ㆍ행정감실ㆍ법무감실ㆍ감찰감실ㆍ정훈감실ㆍ의무감실ㆍ안전감실ㆍ군종감실ㆍ본부사령실.\n②전항의 참모부서중 인사국ㆍ정보국ㆍ작전국ㆍ군수국ㆍ관리국ㆍ통신전자국ㆍ시설국과 기획국을 일반참모부라 하고, 기타의 참모부서를 특별참모부라 한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0006"
      },
      {
        "article_no": "제7조",
        "article_title": "참모부서의 장",
        "chapter": "",
        "content": "제7조 (참모부서의 장)\n①각 참모부서의 장으로써 국에는 국장, 감실에는 감, 본부사령실에는 본부사령을 둔다.\n②각 참모부서의 장을 공군의 장관급 또는 영관급장교중에서 공군참모총장이 보한다.\n③각 참모부서의 장은 상사의 명을 받아 소관사무를 처리하며, 소속부하를 지휘ㆍ감독한다.\n④일반참모부의 장은 소관사무에 관하여 관계특별참모부의 사무를 조정한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0007"
      },
      {
        "article_no": "제8조",
        "article_title": "인사국",
        "chapter": "",
        "content": "제8조 (인사국) 인사국은 인사의 관리ㆍ운영과 충원ㆍ상훈ㆍ전례ㆍ병무 기타 인사에 관한 사항과 교육 및 정병에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0008"
      },
      {
        "article_no": "제9조",
        "article_title": "정보국",
        "chapter": "",
        "content": "제9조 (정보국) 정보국은 항공정보, 전투 및 전략정보, 첩보 및 재외공관주재무관과 주한외국무관과의 연락 기타 군사정보에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0009"
      },
      {
        "article_no": "제10조",
        "article_title": "작전국",
        "chapter": "",
        "content": "제10조 (작전국) 작전국은 작전ㆍ동원ㆍ편제ㆍ장비ㆍ훈련 및 방공에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0010"
      },
      {
        "article_no": "제11조",
        "article_title": "군수국",
        "chapter": "",
        "content": "제11조 (군수국) 군수국은 장비 및 군수물자의 생산ㆍ조달ㆍ정비ㆍ조사ㆍ연구ㆍ보급과 물동계획ㆍ수송 및 후방지원 기타 군수에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0011"
      },
      {
        "article_no": "제12조",
        "article_title": "관리국",
        "chapter": "",
        "content": "제12조 (관리국) 관리국은 예산ㆍ결산ㆍ회계ㆍ재산운영의 관리ㆍ분석ㆍ통계, 군용재산파악과 회계감사 기타 경리에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0012"
      },
      {
        "article_no": "제13조",
        "article_title": "통신전자국",
        "chapter": "",
        "content": "제13조 (통신전자국) 통신전자국은 공군의 통신 및 전자병기에 관한 회계과 운용 기타 통신에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0013"
      },
      {
        "article_no": "제14조",
        "article_title": "시설국",
        "chapter": "",
        "content": "제14조 (시설국) 시설국은 시설의 신영 및 보수와 군용부동산관리 기타 시설에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0014"
      },
      {
        "article_no": "제15조",
        "article_title": "기획국",
        "chapter": "",
        "content": "제15조 (기획국) 기획국은 공군의 운용계획수립 및 이에 관한 조정ㆍ통제와 그 집행상태의 분석ㆍ검토에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0015"
      },
      {
        "article_no": "제16조",
        "article_title": "행정감실",
        "chapter": "",
        "content": "제16조 (행정감실) 행정감실은 관인관수ㆍ문서ㆍ서무 기타 다른 참모부서의 주관에 속하지 아니하는 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0016"
      },
      {
        "article_no": "제17조",
        "article_title": "법무감실",
        "chapter": "",
        "content": "제17조 (법무감실) 법무감실은 군사법의 운영과 군의 행정ㆍ법제 및 군에 관련된 민사행정에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0017"
      },
      {
        "article_no": "제18조",
        "article_title": "감찰감실",
        "chapter": "",
        "content": "제18조 (감찰감실) 감찰감실은 군사검열, 특명사항의 조사, 군사경찰, 방첩, 군풍기유지 및 기지경비에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0018"
      },
      {
        "article_no": "제19조",
        "article_title": "정훈감실",
        "chapter": "",
        "content": "제19조 (정훈감실) 정훈감실은 군인ㆍ군속의 정신함양, 사상전도, 군사에 관한 선전 및 보도와 군사편찬에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0019"
      },
      {
        "article_no": "제20조",
        "article_title": "의무감실",
        "chapter": "",
        "content": "제20조 (의무감실) 의무감실은 군인ㆍ군속의 보건, 진료, 방역, 항공의학 및 약무 기타 의무에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0020"
      },
      {
        "article_no": "제21조",
        "article_title": "안전감실",
        "chapter": "",
        "content": "제21조 (안전감실) 안전감실은 비행안전과 지상안전에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0021"
      },
      {
        "article_no": "제22조",
        "article_title": "군종감실",
        "chapter": "",
        "content": "제22조 (군종감실) 군종감실은 군인과 군속의 종교에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0022"
      },
      {
        "article_no": "제23조",
        "article_title": "본부사령실",
        "chapter": "",
        "content": "제23조 (본부사령실) 본부사령실은 공군본부의 경비ㆍ시설ㆍ관리ㆍ보급ㆍ경리 기타 행정에 관한 사항을 분장한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0023"
      },
      {
        "article_no": "제24조",
        "article_title": "과의 설치",
        "chapter": "",
        "content": "제24조 (과의 설치)\n①각 참모부서에 필요한 과를 둘 수 있다.\n②전항의 과의 설치와 그 사무범위에 관하여는 국방부령으로 정한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0024"
      },
      {
        "article_no": "제25조",
        "article_title": "위원회의 설치",
        "chapter": "",
        "content": "제25조 (위원회의 설치)\n①공군본부에 공군참모총장의 자문에 응하게 하기 위하여 필요한 위원회를 둘 수 있다.\n②전항의 위원회에 관여하는 국방부장관의 승인을 얻어 공군참모총장이 정한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0025"
      },
      {
        "article_no": "제26조",
        "article_title": "정원",
        "chapter": "",
        "content": "제26조 (정원)\n①공군본부에 군인과 군속을 두되, 그 정원은 국방부장관이 정한다.\n②전항의 군인과 군속은 소속 상관의 명을 받아 담당사무를 처리한다.",
        "enforcement_date": "19700420",
        "relations": [],
        "images": [],
        "provision_id": "law:공군본부직제#JO0026"
      }
    ]
  },
