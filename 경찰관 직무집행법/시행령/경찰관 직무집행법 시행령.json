  "body": {
    "format": "articles",
    "article_count": 8,
    "articles": [
      {
        "article_no": "제1조",
        "article_title": "동행검문의 보고",
        "chapter": "",
        "content": "제1조(동행검문의 보고) 경찰관이 경찰관직무집행법(이하 \"법\"이라 한다) 제2조제2항의 규정에 의하여 피질문자를 동행 검문하였을 때에는 24시간 이내에 별지 제1호서식에 의하여 근무관서의 장(지서ㆍ파출소ㆍ출장소에 있어서는 지서장 또는 소장. 이하 같다)에게 보고하여야 한다. 다만, 검문한 결과 형사소송법에 의한 상당절차를 취하였을 때에는 예외로 한다.",
        "enforcement_date": "19700619",
        "relations": [],
        "images": [],
        "provision_id": "law:경찰관직무집행법시행령#JO0001"
      },
      {
        "article_no": "제2조",
        "article_title": "보호조치의 보고",
        "chapter": "",
        "content": "제2조(보호조치의 보고) 경찰관이 법 제3조의 규정에 의하여 보호조치를 취한 자(이하 \"피보호자\"라 한다)가 있을 때에는 지체없이 별지 제2호서식에 의하여 근무관서의 장에게 보고하여야 한다. 피보호자의 보호를 해제하였거나 연고자 또는 법 제3조제3항의 기관에 인계하였을 때 또한 같다.",
        "enforcement_date": "19700619",
        "relations": [],
        "images": [],
        "provision_id": "law:경찰관직무집행법시행령#JO0002"
      },
      {
        "article_no": "제3조",
        "article_title": "가영치의 보고",
        "chapter": "",
        "content": "제3조(가영치의 보고)\n①경찰관이 법 제3조의 규정에 의하여 가영치를 하였을 때에는 12시간이내에 별지 제3호서식에 의하여 근무관서의 장에게 보고하여야 하며, 그 물건을 소지하였던 자에게는 즉시 별지 제4호서식의 증명서를 교부하여야 한다.\n②가영치한 물건에는 가영치한 연월일시, 소지자의 주소 또는 거소, 성명 및 가영치번호를 기입한 표찰을 붙여 소정장소에 보관하여야 한다.\n③제1항전단의 규정은 가영치한 물건을 그 소지자에게 반환하였을 때에 준용한다.",
        "enforcement_date": "19700619",
        "relations": [],
        "images": [],
        "provision_id": "law:경찰관직무집행법시행령#JO0003"
      },
      {
        "article_no": "제4조",
        "article_title": "위험발생방지의 보고",
        "chapter": "",
        "content": "제4조(위험발생방지의 보고) 법 제4조제2항의 규정에 의한 보고는 별지 제5호서식에 의한다.",
        "enforcement_date": "19700619",
        "relations": [],
        "images": [],
        "provision_id": "law:경찰관직무집행법시행령#JO0004"
      },
      {
        "article_no": "제5조",
        "article_title": "범죄의 예방ㆍ제지의 보고",
        "chapter": "",
        "content": "제5조(범죄의 예방ㆍ제지의 보고) 경찰관이 법 제5조의 규정에 의한 조치를 취하였을 때에는 별지 제6호서식에 의하여 지체없이 근무관서의 장에게 보고하여야 한다. 다만, 관계자에 대하여 형사소송법에 의한 상당절차를 취하였을 때에는 예외로 한다.",
        "enforcement_date": "19700619",
        "relations": [],
        "images": [],
        "provision_id": "law:경찰관직무집행법시행령#JO0005"
      },
      {
        "article_no": "제6조",
        "article_title": "위험방지를 위한 출입의 보고",
        "chapter": "",
        "content": "제6조(위험방지를 위한 출입의 보고) 경찰관이 법 제6조제2항의 규정에 의하여 공개시간내에 흥행장ㆍ여관ㆍ요정ㆍ역 기타 다수인이 집합하는 장소에 출입하였을 때에는 별지 제7호서식에 의하여 지체없이 근무관서의 장에게 보고하여야 한다. 다만, 정례적인 순찰이나 근무관서의 장의 특별한 지시에 의한 경우에는 구술로 보고할 수 있다.",
        "enforcement_date": "19700619",
        "relations": [],
        "images": [],
        "provision_id": "law:경찰관직무집행법시행령#JO0006"
      },
      {
        "article_no": "제7조",
        "article_title": "신분증표",
        "chapter": "",
        "content": "제7조(신분증표) 법 제6조제3항의 증표는 경찰관신분증명서로써 갈음한다.",
        "enforcement_date": "19700619",
        "relations": [],
        "images": [],
        "provision_id": "law:경찰관직무집행법시행령#JO0007"
      },
      {
        "article_no": "제8조",
        "article_title": "무기사용의 보고",
        "chapter": "",
        "content": "제8조(무기사용의 보고) 경찰관이 법 제7조의 규정에 의하여 무기를 사용하였을 때에는 지체없이 그 사용의 이유ㆍ일시ㆍ장소 및 결과등을 상세히 근무관서의 장에게 보고하여야 한다.",
        "enforcement_date": "19700619",
        "relations": [],
        "images": [],
        "provision_id": "law:경찰관직무집행법시행령#JO0008"
      }
    ],
