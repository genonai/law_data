    "articles": [
      {
        "article_no": "제1조",
        "article_title": "목적",
        "chapter": "",
        "content": "제1조 (목적) 이 영은 국제금융기구에의가입조치에관한법률(이하 \"법\"이라 한다)의 시행에 관하여 필요한 사항을 규정함을 목적으로 한다.",
        "enforcement_date": "19700330",
        "relations": [],
        "images": [],
        "provision_id": "law:국제금융기구에의가입조치에관한법률시행령#JO0001"
      },
      {
        "article_no": "제2조",
        "article_title": "재정증권매입의 한도액",
        "chapter": "",
        "content": "제2조 (재정증권매입의 한도액) 재무부장관은 법 제4조제2항의 규정에 의하여 한국은행으로 하여금 재정증권을 매입하게 할 한도액을 정하여 동조동항의 규정에 의한 절차를 일괄하여 행할 수 있다.",
        "enforcement_date": "19700330",
        "relations": [],
        "images": [],
        "provision_id": "law:국제금융기구에의가입조치에관한법률시행령#JO0002"
      },
      {
        "article_no": "제3조",
        "article_title": "재정증권의 재발행",
        "chapter": "",
        "content": "제3조 (재정증권의 재발행)\n①재무부장관은 법 제4조제2항의 규정에 의하여 한국은행으로 하여금 재정증권을 매입하게 하기 위하여 필요할 때에는 한국은행이 당해 국제금융기구를 위하여 임치하고 있는 재정증권과 교환하여 이를 그 지급청구금액에 상당하는 재정증권과 그 지급청구금액을 차감한 금액에 상당하는 재정증권으로 분할하여 발행할 수 있다.\n②재무부장관은 법 제4조제2항의 규정에 의한 차입을 위하여 필요할 때에는 한국은행이 당해 국제금융기구를 위하여 임치하고 있는 재정증권과 교환하여 그 지급청구금액을 차감한 금액에 상당하는 재정증권을 발행할 수 있다.",
        "enforcement_date": "19700330",
        "relations": [],
        "images": [],
        "provision_id": "law:국제금융기구에의가입조치에관한법률시행령#JO0003"
      },
      {
        "article_no": "제4조",
        "article_title": "각 국제금융기구에 대한 납입",
        "chapter": "",
        "content": "제4조 (각 국제금융기구에 대한 납입) 한국은행총재는 법 제4조제2항의 규정에 의하여 차입된 금액을 당해 국제금융기구에 납입하여야 한다.",
        "enforcement_date": "19700330",
        "relations": [],
        "images": [],
        "provision_id": "law:국제금융기구에의가입조치에관한법률시행령#JO0004"
      },
      {
        "article_no": "제5조",
        "article_title": "상환금의 계상",
        "chapter": "",
        "content": "제5조 (상환금의 계상) 재무부장관은 법 제4조제2항의 규정에 의하여 한국은행으로부터 차입하거나 한국은행으로 하여금 재정증권을 매입하게 한 때에는 그 내용을 경제기획원장관에게 통보하고 당해 차입금 및 재정증권의 매입에 따르는 상환금액과 그 이자에 상당하는 금액을 예산에 계상하기 위하여 필요한 조치를 의뢰하여야 한다.",
        "enforcement_date": "19700330",
        "relations": [],
        "images": [],
        "provision_id": "law:국제금융기구에의가입조치에관한법률시행령#JO0005"
      },
      {
        "article_no": "제6조",
        "article_title": "보고",
        "chapter": "",
        "content": "제6조 (보고) 한국은행총재는 제4조의 규정에 의하여 당해 국제금융기구에 납입을 한 때에는 재무부장관에게 보고하여야 한다.",
        "enforcement_date": "19700330",
        "relations": [],
        "images": [],
        "provision_id": "law:국제금융기구에의가입조치에관한법률시행령#JO0006"
      }
